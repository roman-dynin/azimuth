generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Route {
  id               Int    @id @default(autoincrement())
  title            String
  parentWaypointId Int?
  lat              Float?
  lng              Float?
}

model Waypoint {
  id      Int @id @default(autoincrement())
  routeId Int
  azimuth Int
  seconds Int
}
