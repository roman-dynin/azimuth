generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model RouteGroup {
  id          Int     @id @default(autoincrement())
  title       String?
  description String?
  color       String?
}

model Route {
  id               Int     @id @default(autoincrement())
  routeGroupId     Int?
  title            String?
  description      String?
  isGuideline      Boolean @default(false)
  anchorWaypointId Int?
  anchorLat        Float?
  anchorLng        Float?
}

model Waypoint {
  id               Int     @id @default(autoincrement())
  routeId          Int
  title            String?
  description      String?
  isNotable        Boolean @default(false)
  targetWaypointId Int?
  azimuth          Int?
  seconds          Int?
}

model Spot {
  id          Int     @id @default(autoincrement())
  title       String?
  description String?
  emoji       String
  lat         Float
  lng         Float
}
